digraph lineage {
  rankdir=LR;
  node [shape=plaintext, fontname="Helvetica"];
  edge [color="#94a3b8", penwidth=1.2];
  "output" [label=<<TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD COLSPAN="3" BGCOLOR="#1f2937"><FONT COLOR="white"><B>Output</B></FONT></TD></TR><TR><TD BGCOLOR="#10b981"><FONT COLOR="white"><B>LITERAL</B></FONT></TD><TD ALIGN="LEFT" PORT="emp_id"><B>emp_id</B> <FONT COLOR="#6b7280">::integer</FONT></TD><TD ALIGN="LEFT"><FONT FACE="monospace">CAST(col1 AS integer)</FONT></TD></TR><TR><TD BGCOLOR="#10b981"><FONT COLOR="white"><B>LITERAL</B></FONT></TD><TD ALIGN="LEFT" PORT="emp_name"><B>emp_name</B> <FONT COLOR="#6b7280">::string</FONT></TD><TD ALIGN="LEFT"><FONT FACE="monospace">CAST(col2 AS string)</FONT></TD></TR><TR><TD BGCOLOR="#10b981"><FONT COLOR="white"><B>LITERAL</B></FONT></TD><TD ALIGN="LEFT" PORT="dept_id"><B>dept_id</B> <FONT COLOR="#6b7280">::integer</FONT></TD><TD ALIGN="LEFT"><FONT FACE="monospace">CAST(col3 AS integer)</FONT></TD></TR><TR><TD BGCOLOR="#10b981"><FONT COLOR="white"><B>LITERAL</B></FONT></TD><TD ALIGN="LEFT" PORT="salary"><B>salary</B> <FONT COLOR="#6b7280">::decimal(12,2)</FONT></TD><TD ALIGN="LEFT"><FONT FACE="monospace">CAST(col4 AS decimal(12,2))</FONT></TD></TR><TR><TD BGCOLOR="#10b981"><FONT COLOR="white"><B>LITERAL</B></FONT></TD><TD ALIGN="LEFT" PORT="hire_date"><B>hire_date</B> <FONT COLOR="#6b7280">::date</FONT></TD><TD ALIGN="LEFT"><FONT FACE="monospace">CAST(col5 AS date)</FONT></TD></TR><TR><TD BGCOLOR="#10b981"><FONT COLOR="white"><B>LITERAL</B></FONT></TD><TD ALIGN="LEFT" PORT="active"><B>active</B> <FONT COLOR="#6b7280">::boolean</FONT></TD><TD ALIGN="LEFT"><FONT FACE="monospace">CAST(col6 AS boolean)</FONT></TD></TR></TABLE>>];
}
